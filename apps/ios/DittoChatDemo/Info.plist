<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>UIBackgroundModes</key>
    <array>
        <!-- Allows Ditto to continue syncing and DittoStoreObserver callbacks to fire
             while the app is backgrounded, enabling local notifications for incoming messages. -->
        <string>fetch</string>
    </array>
</dict>
</plist>
